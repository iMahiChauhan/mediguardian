# MediGuardian — environment setup
# ─────────────────────────────────────────────────────────────────────────────
# Local dev (recommended — single backend process):
#   1. cp backend/.env.example backend/.env
#   2. cp frontend/.env.example frontend/.env.local
#   3. cd backend && pip install -r requirements.txt && uvicorn main:app --reload --port 8000
#   4. cd frontend && npm install && npm run dev
#
# Deploy:
#   Frontend → Vercel  (root: frontend/, env: NEXT_PUBLIC_API_URL)
#   Backend  → Render  (root: backend/,  start: uvicorn main:app --host 0.0.0.0 --port $PORT)
#   See render.yaml for a one-click Render blueprint.
