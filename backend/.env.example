# Copy to backend/.env for local development
# On Render: set these in the dashboard (DATABASE_URL is auto-set when Postgres is linked)

ENVIRONMENT=development
DEBUG=true

# Local SQLite (default). Render injects postgres:// when you link a database.
DATABASE_URL=sqlite:///./mediguardian.db
AUTO_CREATE_TABLES=false

# Required before writing encrypted PHI/PII fields with pgcrypto.
PHI_ENCRYPTION_KEY=replace-with-strong-32-byte-minimum-secret
PHI_LOOKUP_PEPPER=replace-with-independent-lookup-pepper

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Comma-separated — add your Vercel URL after deploy
CORS_ORIGINS=http://localhost:3000

# Only needed for docker-compose microservice mode (gateway/main.py)
SYMPTOM_SERVICE_URL=http://localhost:8001
AUTH_SERVICE_URL=http://localhost:8002
HISTORY_SERVICE_URL=http://localhost:8003
REPORT_SERVICE_URL=http://localhost:8004
HOSPITAL_SERVICE_URL=http://localhost:8005
CHATBOT_SERVICE_URL=http://localhost:8006
